# Database (Neon/Vercel Postgres)
# Get these values from your Vercel Postgres dashboard
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# NextAuth v5
# Generate AUTH_SECRET: `openssl rand -base64 32`
AUTH_SECRET=
# Update this for production deployment
AUTH_URL=http://localhost:3000

# Node Environment
NODE_ENV=development